rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection: Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'lastLogin']));
      
      function isValidUser(data) {
        return data.uid == request.auth.uid
          && data.email is string && data.email.size() <= 200
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
          && (data.lastLogin == null || data.lastLogin is number)
          && (data.createdAt == null || data.createdAt is number);
      }
    }

    // --- Collection: Mistakes ---
    match /mistakes/{mistakeId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && isValidMistake(request.resource.data);
      allow update: if isSignedIn() 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid
                    && isValidMistake(request.resource.data)
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['selected', 'question', 'notes']));
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidMistake(data) {
        return data.userId == request.auth.uid
          && data.question is string && data.question.size() <= 5000
          && (data.notes == null || (data.notes is string && data.notes.size() <= 2000))
          && (data.image == null || (data.image is string && data.image.size() <= 2000000))
          && (data.selected is bool)
          && data.createdAt is number;
      }
    }
  }
}
